# Application
APP_ENV=development
APP_NAME=RAHFIT AI API
RAHFIT_DEBUG=false
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# HTTP and browser access (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=rahfit_ai

# Security — replace with a long random value outside local development
JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Basic request throttling
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# AI provider infrastructure (disabled safely by default)
AI_FEATURE_ENABLED=false
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4.1-mini
AI_REQUEST_TIMEOUT_SECONDS=15
AI_MAX_OUTPUT_TOKENS=600

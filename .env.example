# Application
APP_ENV=development
APP_NAME=RAHFIT AI API
DEBUG=false
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# HTTP and browser access (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=rahfit_ai

# Security — replace with a long random value outside local development
JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Basic request throttling
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Local development only. Keep the /api/v1 prefix; a trailing slash is normalized.
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# Vercel Production/Preview: set this in the Vercel dashboard, never commit it.
# It must be the public HTTPS backend URL and include /api/v1.
# VITE_API_BASE_URL=https://api.<your-domain>/api/v1

# Local development only. A trailing slash is normalized and /api/v1 is added once.
VITE_API_BASE_URL=http://127.0.0.1:8000

# Vercel Production/Preview: set this in the Vercel dashboard, never commit it.
# It must be the public HTTPS backend origin; /api/v1 is added once.
# VITE_API_BASE_URL=https://api.<your-domain>
